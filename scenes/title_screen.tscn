[gd_scene load_steps=2 format=3 uid="uid://title_screen"]

[ext_resource type="Script" path="res://scripts/title_screen.gd" id="1_script"]

[node name="TitleScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.0, 0.0, 0.0, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -150.0
offset_right = 200.0
offset_bottom = 150.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 30

[node name="TitleLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1.0, 0.0, 0.0, 1)
theme_override_font_sizes/font_size = 80
text = "TECHNO"
horizontal_alignment = 1
vertical_alignment = 1

[node name="Spacer" type="Control" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)

[node name="NewGameButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 24
text = "New Game"

[node name="InfoButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 24
text = "Info"

[node name="HighScoresButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 24
text = "High Scores"

[node name="ExitButton" type="Button" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(250, 50)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 24
text = "Exit"

[node name="InfoPanel" type="PanelContainer" parent="."]
unique_name_in_owner = true
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -160.0
offset_right = 200.0
offset_bottom = 160.0
grow_horizontal = 2
grow_vertical = 2

[node name="MarginContainer" type="MarginContainer" parent="InfoPanel"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBox" type="VBoxContainer" parent="InfoPanel/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="InfoPanel/MarginContainer/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Controls"
horizontal_alignment = 1

[node name="Sep" type="HSeparator" parent="InfoPanel/MarginContainer/VBox"]
layout_mode = 2

[node name="Controls" type="Label" parent="InfoPanel/MarginContainer/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Arrow Keys: Move left/right
Up/Down: Climb tree trunks
Space: Jump
Escape: Pause"

[node name="Spacer" type="Control" parent="InfoPanel/MarginContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="CloseButton" type="Button" parent="InfoPanel/MarginContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(120, 40)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 20
text = "Close"

[connection signal="pressed" from="VBoxContainer/NewGameButton" to="." method="_on_new_game_button_pressed"]
[connection signal="pressed" from="VBoxContainer/InfoButton" to="." method="_on_info_button_pressed"]
[connection signal="pressed" from="VBoxContainer/HighScoresButton" to="." method="_on_high_scores_button_pressed"]
[connection signal="pressed" from="VBoxContainer/ExitButton" to="." method="_on_exit_button_pressed"]
[connection signal="pressed" from="InfoPanel/MarginContainer/VBox/CloseButton" to="." method="_on_close_info_button_pressed"]
